{
  "name": "transaction-event-gateway",
  "version": "0.1.0",
  "description": "Backend service scaffold for transaction event processing.",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build && tsc -p tsconfig.migrations.json",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:worker": "node dist/worker.js",
    "typeorm": "typeorm-ts-node-commonjs -d src/database/data-source.ts",
    "typeorm:prod": "typeorm -d dist/database/data-source.js",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert",
    "migration:show": "npm run typeorm -- migration:show",
    "migration:run:prod": "npm run typeorm:prod -- migration:run",
    "migration:revert:prod": "npm run typeorm:prod -- migration:revert",
    "migration:show:prod": "npm run typeorm:prod -- migration:show",
    "lint": "eslint \"{src,test,migrations}/**/*.ts\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "jest --config jest.config.js",
    "test:e2e": "jest --config test/jest-e2e.config.js",
    "smoke:local": "bash scripts/smoke-local.sh"
  },
  "overrides": {
    "@nestjs/platform-express": {
      "multer": "^2.2.0"
    },
    "@nestjs/swagger": {
      "js-yaml": "^4.2.0"
    }
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/typeorm": "^11.0.2",
    "bullmq": "^5.79.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^17.4.2",
    "ioredis": "^5.11.1",
    "joi": "^17.13.3",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.30"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.0.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.0",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0"
  }
}
